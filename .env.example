MYSQL_DSN=device_issuer:device_issuer_password@tcp(127.0.0.1:3306)/device_cert_issuer?parseTime=true
INTERMEDIATE_CERT_PATH=/absolute/path/to/intermediate.cert.pem
INTERMEDIATE_PRIVATE_KEY_PATH=/absolute/path/to/intermediate.key.pkcs8.pem
INTERMEDIATE_PRIVATE_KEY_PASSPHRASE=
INTERMEDIATE_CHAIN_PATH=/absolute/path/to/intermediate.chain.pem

SERVER_PORT=8080
SERVER_READ_TIMEOUT=5s
SERVER_READ_HEADER_TIMEOUT=2s
SERVER_WRITE_TIMEOUT=10s
SERVER_IDLE_TIMEOUT=30s
SERVER_SHUTDOWN_TIMEOUT=10s
SERVER_REQUEST_BODY_LIMIT=32768

SIGNER_MODE=file
SIGNER_STRICT_FILE_PERMS=true

CERT_VALIDITY=720h
ALLOWED_KEY_ALGORITHMS=RSA,ECDSA,Ed25519
ALLOWED_CURVES=P256,P384,Ed25519
ALLOWED_RSA_BITS=2048,3072,4096
DEFAULT_PROFILE=default
ALLOWED_PROFILES=default

ISSUER_ORGANIZATION=Device PKI
ISSUER_ORGANIZATIONAL_UNIT=Device Certificates
ISSUER_COUNTRY=KR
ISSUER_PROVINCE=Seoul
ISSUER_LOCALITY=Seoul
ISSUER_COMMON_NAME=Device Certificate

LOG_LEVEL=INFO
